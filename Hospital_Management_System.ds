	reports
	{
		list appointment_Report
		{
			displayName = "All Appointments"
			show all rows from appointment    
			(
				patient as "Patient"
				doctor as "Doctor"
				scheduled_date as "Scheduled Date"
				scheduled_time as "Scheduled Time"
				appointment_status as "Appointment Status"
				priority as "Priority"
				notes as "Notes"
				confirmed_by as "Confirmed By"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (appointment_status == "Completed")
				fields = [appointment_status]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (appointment_status == "Rescheduled")
				fields = [appointment_status]
				format = "color:#000000;background-color:#1bbc9b;"
				}
			)
		}
		kanban appointment_by_appointment_status
		{
			displayName = "Appointment Statuses"
			show all rows from appointment    
			(
				patient as "Patient"
				doctor as "Doctor"
				scheduled_date as "Scheduled Date"
				scheduled_time as "Scheduled Time"
				appointment_status as "Appointment Status"
				priority as "Priority"
				notes as "Notes"
				confirmed_by as "Confirmed By"
			)
			options
			(
	 			display field = appointment_status
	 		)
		}
		list emergency_case_Report
		{
			displayName = "All Emergency Cases"
			show all rows from emergency_case    
			(
				patient as "Patient"
				doctor as "Doctor"
				emergency_level as "Emergency Level"
				reported_time as "Reported Time"
				treatment_started as "Treatment Started"
				treatment_status as "Treatment Status"
				response_time as "Response Time"
				assigned_team as "Assigned Team"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (emergency_level == "Level 2")
				fields = [emergency_level]
