 application "Hospital Management System"
 {
 	date format = "dd-MMM-yyyy"
 	time zone = "America/Los_Angeles"
 	time format = "24-hr"
 	forms
	{
		form appointment
		{
			displayname = "Appointment"
			success message = "Appointment Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			patient
			(
				type = list	
				displayname = "Patient"
				values  = patient.ID
    			displayformat = [patient_name]
				allow new entries
				[
					displayname = "Add New"
				]
				sortorder = ascending
				height = 13px
	 			row = 1
	 			column = 1   
				width = medium
			)
			doctor
			(
				type = list	
				displayname = "Doctor"
				values  = doctor.ID
    			displayformat = [doctor_name]
				allow new entries
				[
					displayname = "Add New"
				]
				sortorder = ascending
				height = 13px
	 			row = 1
	 			column = 1   
				width = medium
			)
			scheduled_date
			(
    			type = date
				displayname = "Scheduled Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			scheduled_time
			(
    			type = time
				displayname = "Scheduled Time"
				timedisplayoptions = "hh:mm:ss" 
	 			row = 1
	 			column = 1   
				width = medium
			)
			appointment_status
			(
				type = picklist
				displayname = "Appointment Status"
				values = {"Completed","Confirmed","Canceled","Rescheduled"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			priority
			(
				type = picklist
				displayname = "Priority"
				values = {"High","Low","Medium","Critical"}
				others option = true
